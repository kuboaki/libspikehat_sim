<mujoco model="test_motor">
  <compiler angle="radian" meshdir="meshes/"/>
  <option timestep="0.0002" gravity="0 0 -9.81"/>
  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.3 0.3 0.3"/>
  </visual>
  <asset>
    <mesh name="motor_body_mesh" file="motor_body.stl" scale="1 1 1"/>
    <mesh name="motor_rotor_mesh" file="motor_rotor.stl" scale="1 1 1"/>
  </asset>
  <worldbody>
    <light name="light" pos="0 0 1" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="1 1 0.01" rgba="0.6 0.6 0.6 1"/>
    <body name="motor_body" pos="0 0 0" euler="0 0 0">
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>
      <geom type="mesh" mesh="motor_body_mesh"
            rgba="0.5 0.5 0.5 1"
            contype="0" conaffinity="0"/>
      <body name="motor_rotor" pos="0.0001 0.0239 0.0160">
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>
        <joint name="motor_joint" type="hinge" axis="0 0 -1"
               damping="0.55" armature="0.001"/>
        <geom type="mesh" mesh="motor_rotor_mesh"
              rgba="0.8 0.4 0.1 1"
              contype="0" conaffinity="0"/>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor name="motor_ctrl" joint="motor_joint"
           gear="3" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
</mujoco>

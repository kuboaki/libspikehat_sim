<mujoco model="test_distance_sensor">

  <compiler angle="degree" meshdir="meshes/"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
  </visual>

  <!--
    距離センサーテスト用モデル（LEGOメッシュ版）

    構成:
      - sensor_mount: 距離センサー本体（固定）
          components/distance_sensor_body.xml をinclude
          distance_site: センサーの検出点（前方+Y を向く、ボディ内側5mm）
      - wall_body: 壁（スライダーで前後に移動）
          obstacle_wall_a.stl を使用

    操作:
      - Controlスライダー "wall_slide_ctrl" で壁を前後に移動
      - センサーから壁までの距離が変わる
      - 有効範囲: 50mm〜300mm

    座標系:
      - X軸: 左右
      - Y軸: 前後（プラスが前方）
      - Z軸: 上下（プラスが上）

    センサー位置: pos="0 0 0.044"（Studio testモデルのマウント高さ）
    distance_site: Y=0.0108m（検出面から5mm内側）
    壁の初期位置: Y=0.175（センサーから約150mm前方）
    壁の移動範囲: Y=0.050〜0.400

    距離の計測:
      レイキャストは distance_site（ボディ内側）から+Y方向に発射。
      wall_body pos Y と計測距離の関係:
        計測距離 ≈ wall_body_Y - 0.0243m
          （0.0243 = site_Y(0.0108) + 壁の半厚(0.0271/2=0.0135)）
      例: wall_body pos Y=0.175m → 計測距離 ≈ 0.1507m = 150.7mm
  -->

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.7 0.7 0.7" rgb2="0.8 0.8 0.8"/>
    <material name="grid_mat" texture="grid" texrepeat="4 4"/>

    <!-- 距離センサーメッシュ -->
    <mesh name="distance_sensor_mesh" file="distance_sensor.stl"/>

    <!-- 壁メッシュ -->
    <mesh name="obstacle_wall_a_mesh" file="obstacle_wall_a.stl"/>
  </asset>

  <worldbody>
    <light name="light_top" pos="0 0 1.0" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1" directional="true"/>

    <!-- 床 -->
    <geom name="floor" type="plane" size="0.5 0.5 0.01"
          material="grid_mat" contype="1" conaffinity="1"/>

    <!-- ────────────────────────────────────────────────
         距離センサー本体（固定）
         sensor_mount の pos でセンサー搭載位置を指定
         distance_sensor_body.xml: euler="0 0 0" で検出面が+Y（前方）
    ──────────────────────────────────────────────── -->
    <!-- sensor_mount: 位置決め用ボディ。
         MuJoCoの<include>はルート要素を除去して子要素を挿入するため、
         inertial/geom/siteはdistance_sensor_body.xmlから提供される。
         センサーの向きを変える場合はここのeulerで指定する（例: euler="0 0 90"）-->
    <body name="sensor_mount" pos="0 0 0.0323">
      <include file="components/distance_sensor_body.xml"/>
    </body>

    <!-- ────────────────────────────────────────────────
         壁（スライダーで前後に移動）
         obstacle_wall_a.stl: bottom_z centering（底面Z=0）
         初期位置: センサーから約150mm前方
    ──────────────────────────────────────────────── -->
    <!-- euler="0 0 180": LDraw→MuJoCoのX軸反転による向き反転を補正 -->
    <!-- 初期距離: IOファイルから算出した117.3mm -->
    <body name="wall_body" pos="0 0.1173 0" euler="0 0 180">
      <!-- axis="0 -1 0": euler="0 0 180"でbody Y軸が反転するため逆向きに設定
           正の値→壁が離れる（距離増加）、負の値→壁が近づく（距離減少）-->
      <joint name="wall_slide" type="slide" axis="0 -1 0"
             range="-0.225 0.125" damping="10.0"/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>

      <geom name="wall_geom" type="mesh" mesh="obstacle_wall_a_mesh"
            contype="1" conaffinity="1" rgba="0.8 0.8 0.2 0.8"/>
    </body>

  </worldbody>

  <!-- 壁スライダーアクチュエーター -->
  <actuator>
    <position name="wall_slide_ctrl" joint="wall_slide"
              kp="100" ctrllimited="true" ctrlrange="-0.225 0.125"/>
  </actuator>

  <!-- センサー -->
  <sensor>
    <jointpos name="wall_position" joint="wall_slide"/>
    <framepos name="distance_site_pos" objtype="site" objname="distance_site"/>
  </sensor>

</mujoco>

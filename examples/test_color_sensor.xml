<mujoco model="test_color_sensor">

  <compiler angle="degree" meshdir="meshes/"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
  </visual>

  <!--
    カラーセンサーテスト用モデル（LEGOブロック版）

    構成:
      - color_sensor_body: カラーセンサー本体（スライダーで左右に移動）
          初期位置: tile_yellow(X=0) の上
          pos Y=-0.0116: bottom_z STL(高さ0.0231m)のZ中心をworld Y=0に合わせる補正
          pos Z= 0.0405: color_blocks_with_color_sensor.io から取得したセンサー高さ
          euler なし: スライダー axis="1 0 0" が world X に沿うよう outer body は無回転
          include: color_sensor_body.xml が euler="-90 0 0"（検出面→下向き）を担う

      - color_blocks: カラーブロック群（LEGOメッシュ）
          base_plate, gap_cover, tile_black/blue/green/yellow/red/white/brown

    操作:
      - Controlスライダー "sensor_slide_ctrl" でセンサーを左右（X方向）に移動
      - センサーが各色ブロックの上に来るとHSV値が変わる

    タイル配置（X軸）:
      tile_black  : X=+0.0720
      tile_blue   : X=+0.0480
      tile_green  : X=+0.0240
      tile_yellow : X= 0.0000
      tile_red    : X=-0.0240
      tile_white  : X=-0.0480
      tile_brown  : X=-0.0720

    センサー高さ:
      pos Z=0.0405m（color_blocks_with_color_sensor.io 実測値）
      検出面高さ = Z - color_site_Y = 0.0405 - 0.0063 = 0.0342m
      タイル上面(約0.010m)から約0.024m上方
  -->

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.7 0.7 0.7" rgb2="0.8 0.8 0.8"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8"/>

    <mesh name="color_sensor_mesh" file="color_sensor.stl"/>

    <mesh name="base_plate_mesh"  file="base_plate.stl"/>
    <mesh name="tile_black_mesh"  file="tile_black.stl"/>
    <mesh name="tile_blue_mesh"   file="tile_blue.stl"/>
    <mesh name="tile_green_mesh"  file="tile_green.stl"/>
    <mesh name="tile_yellow_mesh" file="tile_yellow.stl"/>
    <mesh name="tile_red_mesh"    file="tile_red.stl"/>
    <mesh name="tile_white_mesh"  file="tile_white.stl"/>
    <mesh name="tile_brown_mesh"  file="tile_brown.stl"/>
  </asset>

  <worldbody>
    <light name="light_top" pos="0 0 1.0" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1" directional="true"/>

    <geom name="floor" type="plane" size="0.5 0.5 0.01"
          material="grid_mat" contype="1" conaffinity="1"/>

    <!-- ────────────────────────────────────────────────
         カラーブロック群（固定）
         shared_offsetにより全メッシュの位置関係が正しく保たれる
    ──────────────────────────────────────────────── -->
    <body name="color_blocks" pos="0 0 0">
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>
      <geom name="base_plate_geom" type="mesh" mesh="base_plate_mesh"
            contype="0" conaffinity="0" rgba="0.388 0.373 0.322 1"/>
      <geom name="tile_black_geom" type="mesh" mesh="tile_black_mesh"
            contype="0" conaffinity="0" rgba="0.027 0.027 0.027 1"/>
      <geom name="tile_blue_geom" type="mesh" mesh="tile_blue_mesh"
            contype="0" conaffinity="0" rgba="0.000 0.089 0.515 1"/>
      <geom name="tile_green_geom" type="mesh" mesh="tile_green_mesh"
            contype="0" conaffinity="0" rgba="0.000 0.373 0.165 1"/>
      <geom name="tile_yellow_geom" type="mesh" mesh="tile_yellow_mesh"
            contype="0" conaffinity="0" rgba="0.992 0.843 0.000 1"/>
      <geom name="tile_red_geom" type="mesh" mesh="tile_red_mesh"
            contype="0" conaffinity="0" rgba="0.578 0.010 0.002 1"/>
      <geom name="tile_white_geom" type="mesh" mesh="tile_white_mesh"
            contype="0" conaffinity="0" rgba="0.991 0.991 0.991 1"/>
      <geom name="tile_brown_geom" type="mesh" mesh="tile_brown_mesh"
            contype="0" conaffinity="0" rgba="0.294 0.157 0.071 1"/>
    </body>

    <!-- ────────────────────────────────────────────────
         カラーセンサー本体（<include> 方式）
         pos X=0    : 初期位置 tile_yellow の上
         pos Y=-0.0116: bottom_z STL(H=0.0231m)のZ中心をworld Y=0に揃える補正
         pos Z=0.0405: color_blocks_with_color_sensor.io 実測値
         euler="-90 0 0": 検出面を world -Z（下向き）に回転。Rx(-90°)はX軸を変えないので
                  slider axis="1 0 0" は world X に沿ったまま ✓
         include    : color_sensor_body.xml（body タグは除去され inertial/geom/site が挿入）
    ──────────────────────────────────────────────── -->
    <body name="color_sensor_body" pos="0 -0.0116 0.0405" euler="-90 0 0">
      <joint name="sensor_slide" type="slide" axis="1 0 0"
             range="-0.090 0.090" damping="10.0"/>
      <include file="components/color_sensor_body.xml"/>
    </body>

  </worldbody>

  <actuator>
    <position name="sensor_slide_ctrl" joint="sensor_slide"
              kp="100" ctrllimited="true" ctrlrange="-0.090 0.090"/>
  </actuator>

  <sensor>
    <jointpos name="sensor_position" joint="sensor_slide"/>
    <framepos name="color_site_pos" objtype="site" objname="color_site"/>
  </sensor>

</mujoco>

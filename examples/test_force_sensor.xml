<mujoco model="test_force_sensor">

  <compiler angle="degree" meshdir="meshes/"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
  </visual>

  <!--
    フォースセンサーテスト（button + press_block = 1ボディ版）

    button と press_block はシャフトで接合された1つの剛体。
    press_ctrl スライダーで button_slide を直接制御する。
    ctrl=0 → 初期位置（突き出た状態）、スプリングで自動復元
    ctrl=0.010 → 完全埋没
  -->

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.7 0.7 0.7" rgb2="0.8 0.8 0.8"/>
    <material name="grid_mat" texture="grid" texrepeat="4 4"/>
    <mesh name="force_sensor_body_mesh" file="force_sensor_body.stl"/>
    <mesh name="button_mesh"            file="button.stl"/>
    <mesh name="press_block_mesh"       file="press_block.stl"/>
  </asset>

  <worldbody>
    <light name="light_top" pos="0 0 1.0" dir="0 0 -1"
           diffuse="0.8 0.8 0.8" specular="0.1 0.1 0.1" directional="true"/>
    <geom name="floor" type="plane" size="0.5 0.5 0.01"
          material="grid_mat" contype="1" conaffinity="1"/>

    <body name="sensor_mount" pos="0 0 0">
      <include file="components/force_sensor_body.xml"/>
    </body>

  </worldbody>

  <!-- button_slide を直接位置制御（button + press_block が一緒に動く）
       スプリング(stiffness=200)で ctrl=0 に戻したとき自動復元 -->
  <actuator>
    <position name="press_ctrl" joint="button_slide"
              kp="1000" ctrllimited="true" ctrlrange="0 0.015"/>
  </actuator>

  <sensor>
    <jointpos name="button_pos" joint="button_slide"/>
    <!-- force_touch: 外部から button/press_block に触れた力を検出
         スプリング変位からも計算可能: force = 1000 × button_pos [N] -->
    <touch name="force_touch" site="force_site"/>
  </sensor>

</mujoco>
